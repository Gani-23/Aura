LSA_API_KEY=change-me-in-production
LSA_ENVIRONMENT_NAME=prod
LSA_RUN_EMBEDDED_WORKER=0
LSA_PIP_INSTALL_EXTRAS=
LSA_DATABASE_URL=sqlite:////app/data/control_plane.db
LSA_ENABLE_POSTGRES_RUNTIME_SNAPSHOTS_AUDITS=0
LSA_POSTGRES_RUNTIME_SNAPSHOTS_AUDITS_DATABASE_URL=
LSA_ENABLE_POSTGRES_RUNTIME_JOBS=0
LSA_POSTGRES_RUNTIME_JOBS_DATABASE_URL=
LSA_SQLITE_BUSY_TIMEOUT_MS=5000
LSA_CONTROL_PLANE_ALERTS_ENABLED=1

LSA_API_KEY=change-me-in-production
LSA_ENVIRONMENT_NAME=prod
LSA_RUN_EMBEDDED_WORKER=0
LSA_CONTROL_PLANE_ALERTS_ENABLED=1
LSA_PIP_INSTALL_EXTRAS=postgres

POSTGRES_DB=lsa_prod
POSTGRES_USER=lsa
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_PORT=5432

LSA_DATABASE_URL=postgresql://lsa:change-me-in-production@postgres:5432/lsa_prod
LSA_ENABLE_POSTGRES_RUNTIME_SNAPSHOTS_AUDITS=1
LSA_POSTGRES_RUNTIME_SNAPSHOTS_AUDITS_DATABASE_URL=postgresql://lsa:change-me-in-production@postgres:5432/lsa_prod
LSA_ENABLE_POSTGRES_RUNTIME_JOBS=1
LSA_POSTGRES_RUNTIME_JOBS_DATABASE_URL=postgresql://lsa:change-me-in-production@postgres:5432/lsa_prod

FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

ARG LSA_PIP_INSTALL_EXTRAS=""

WORKDIR /app

RUN useradd --create-home --shell /usr/sbin/nologin lsa

COPY pyproject.toml README.md /app/
COPY lsa /app/lsa
COPY ebpf /app/ebpf

RUN pip install --upgrade pip && \
    if [ -n "$LSA_PIP_INSTALL_EXTRAS" ]; then \
      pip install -e ".[${LSA_PIP_INSTALL_EXTRAS}]"; \
    else \
      pip install -e .; \
    fi
RUN mkdir -p /app/data && chown -R lsa:lsa /app

USER lsa

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --retries=3 CMD python -c "import sys, urllib.request; sys.exit(0 if urllib.request.urlopen('http://127.0.0.1:8000/health').getcode() == 200 else 1)"

CMD ["uvicorn", "lsa.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
